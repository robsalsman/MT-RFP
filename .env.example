# Copy to .env and fill in.

# AI provider — powers the RFP Analyst pass and response drafting. Set ONE
# of the two keys below (Nemotron wins if both are set; force with
# MTRFP_LLM_PROVIDER=nemotron|anthropic). Without any key the app still
# syncs/scores; AI analysis and cover letters are replaced with
# deterministic fallbacks / [NEEDS INPUT] placeholders.

# Option A: NVIDIA Nemotron (OpenAI-compatible; key from build.nvidia.com)
NEMOTRON_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# Option B: Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Voice (assistant speech-to-speech / TTS) ------------------------------
# Uses the same NVIDIA key via NVIDIA-hosted Riva speech services:
# Parakeet ASR + Magpie TTS on grpc.nvcf.nvidia.com. Override only if NVIDIA
# rotates function IDs or you want a different voice.
# NVIDIA_ASR_FUNCTION_ID=d3fe9151-442b-4204-a70d-5fcc597fd610
# NVIDIA_TTS_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
# NVIDIA_TTS_VOICE=Magpie-Multilingual.EN-US.Sofia

# USAC Open Data (Socrata) app token — free, avoids throttling.
# Register at https://opendata.usac.org/ (Sign up -> Developer Settings ->
# Create new app token). Reads work without it, but get rate-limited sooner.
USAC_APP_TOKEN=

# --- Optional tuning -------------------------------------------------------
# How far back to pull certified Form 470s (days).
MTRFP_LOOKBACK_DAYS=60
# Scheduled sync interval (hours). "Refresh Now" in the UI is always available.
MTRFP_SYNC_INTERVAL_HOURS=6
# SODA response cache TTL (seconds).
MTRFP_HTTP_CACHE_TTL=1800
